{
  "rules": {
    "rooms": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "chat": {
          "$msgId": {
            ".validate": "newData.child('text').isString() && newData.child('text').val().length <= 200"
          }
        }
      }
    },
    "codes": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && (!data.exists() || data.child('hostUid').val() === auth.uid)",
        ".validate": "$code.matches(/^[A-Z0-9]{6}$/)"
      }
    },
    "matchmaking": {
      ".read": "auth != null",
      "queue": {
        "$uid": { ".write": "auth != null && $uid === auth.uid" }
      },
      "assign": {
        "$uid": { ".write": "auth != null" }
      }
    },
    "presence": {
      "$uid": { ".read": "auth != null", ".write": "auth != null && $uid === auth.uid" }
    }
  }
}
